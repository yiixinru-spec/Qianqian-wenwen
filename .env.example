LLM_API_KEY=replace_with_your_api_key

# Option A: Zhipu AI
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
LLM_MODEL=glm-4.5-flash

# Option B: SiliconFlow, OpenAI-compatible. Fill a SiliconFlow key above.
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Option C: PackyAPI, OpenAI-compatible. Fill a PackyAPI key above.
# LLM_BASE_URL=https://www.packyapi.com/v1
