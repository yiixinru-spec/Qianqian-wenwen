# Option D: DeepSeek, OpenAI-compatible. Fill a DeepSeek key above.
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

LLM_TIMEOUT=45
LLM_MAX_TOKENS=900
HOST=127.0.0.1
PORT=8000
